# Copy to .env and fill in.
# The demo runs fully without a key (deterministic MOCK reasoning),
# but supply an OpenAI key for real agentic reasoning + embeddings-based RAG.

OPENAI_API_KEY=

# Model used by the agents. gpt-4o-mini is fast + cheap and plenty for the demo.
OPENAI_MODEL=gpt-4o-mini

# Embedding model for the RAG runbook store.
OPENAI_EMBED_MODEL=text-embedding-3-small

# Host/port for the demo server.
HOST=127.0.0.1
PORT=8000
